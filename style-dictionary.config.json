{
  "source": ["src/tokens/**/*.json"],
  "platforms": {
    "web": {
      "transformGroup": "js",
      "buildPath": "dist/tokens/web/",
      "files": [
        {
          "destination": "tokens.js",
          "format": "javascript/module"
        }
      ]
    },
    "ios": {
      "transformGroup": "ios",
      "buildPath": "dist/tokens/ios/",
      "files": [
        {
          "destination": "colors.json",
          "format": "json"
        }
      ]
    },
    "android": {
      "transformGroup": "android",
      "buildPath": "dist/tokens/android/",
      "files": [
        {
          "destination": "colors.json",
          "format": "json"
        }
      ]
    }
  }
}
